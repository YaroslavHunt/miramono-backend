{
  "name": "miramono-backend",
  "version": "0.1.0",
  "description": "Backend API for the MIRAMONO Dentistry clinic website",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,test}/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typeorm": "tsx ./node_modules/typeorm/cli.js -d ./src/database/data-source.ts",
    "migration:generate": "npm run typeorm -- migration:generate ./src/database/migrations/$npm_config_name",
    "migration:create": "tsx ./node_modules/typeorm/cli.js migration:create ./src/database/migrations/$npm_config_name",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert",
    "migration:show": "npm run typeorm -- migration:show",
    "seed": "ts-node ./src/database/seeds/seed.ts",
    "docker:up": "docker compose up -d --build",
    "docker:up:fg": "docker compose up --build",
    "docker:db": "docker compose up -d postgres redis",
    "docker:down": "docker compose down",
    "docker:down:vol": "docker compose down -v",
    "docker:logs": "docker compose logs -f app",
    "docker:ps": "docker compose ps",
    "db:reset": "docker compose down -v && docker compose up -d postgres redis"
  },
  "dependencies": {
    "@keyv/redis": "5.1.6",
    "@nestjs/cache-manager": "3.1.2",
    "@nestjs/common": "11.1.24",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.24",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.1.24",
    "@nestjs/swagger": "11.4.4",
    "@nestjs/terminus": "11.1.1",
    "@nestjs/throttler": "6.5.0",
    "@nestjs/typeorm": "11.0.1",
    "argon2": "0.44.0",
    "cache-manager": "7.2.8",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "dotenv": "17.4.2",
    "helmet": "8.2.0",
    "keyv": "5.6.0",
    "nestjs-i18n": "10.8.4",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "pg": "8.21.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "typeorm": "1.0.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@nestjs/cli": "11.0.21",
    "@nestjs/schematics": "11.1.0",
    "@nestjs/testing": "11.1.24",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/multer": "2.1.0",
    "@types/node": "25.9.1",
    "@types/passport-jwt": "4.0.1",
    "@types/supertest": "7.2.0",
    "eslint": "10.4.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "globals": "17.6.0",
    "jest": "30.4.2",
    "prettier": "3.8.3",
    "source-map-support": "0.5.21",
    "supertest": "7.2.2",
    "ts-jest": "29.4.11",
    "ts-node": "10.9.2",
    "tsx": "4.22.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.60.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "setupFiles": [
      "reflect-metadata"
    ],
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}

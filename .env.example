# Application
NODE_ENV=development
PORT=3000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=miramono
DB_PASSWORD=change_me
DB_NAME=miramono

# Redis (caching only)
REDIS_HOST=localhost
REDIS_PORT=6379

# Rate limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=120

# Auth (JWT) — generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=change_me
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change_me
JWT_REFRESH_TTL=7d

# Admin seed (created on boot if absent)
ADMIN_LOGIN=admin
ADMIN_PASSWORD=change_me

# Uploads (local file storage for images)
UPLOAD_DIR=uploads

# Payments (LiqPay sandbox — get keys from your LiqPay merchant cabinet)
LIQPAY_PUBLIC_KEY=change_me
LIQPAY_PRIVATE_KEY=change_me
LIQPAY_SANDBOX=true

# SEO / public site (absolute URLs in sitemap, LiqPay callbacks)
PUBLIC_SITE_URL=http://localhost:3000

# i18n
DEFAULT_LOCALE=uk
